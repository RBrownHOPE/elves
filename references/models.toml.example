# Local Cobbler external-agent preferences (schema example)
#
# Copy ideas from this file into the intentionally ignored checkout file:
#   .elves/models.toml
#
# Precedence for active routes (highest wins):
#   1. committed Survival Guide route snapshot / explicit project required values
#   2. local ignored .elves/models.toml  (this schema)
#   3. installed/user config.json
#   4. native host defaults (host-native for every role)
#
# Rules:
# - Never stage or commit .elves/models.toml
# - Never put raw credentials, tokens, or personal absolute paths here
# - Environment variable *names* are fine (for example OPENROUTER_API_KEY)
# - required = true is valid only as an explicit project choice (usually mirrored
#   into the Survival Guide); public defaults stay native-first
# - Profile names are harness/capability labels, not prestige model IDs
# - Built-in adapters: claude-code, grok-build, codex-fugu, gemini-cli,
#   antigravity-cli, custom-cli, host-native
# - Optional tier profiles: claude-code-planning / claude-code-labor,
#   codex-fugu-planning / codex-fugu-labor (set requested_model per tier locally)
# - Google gemini-cli / antigravity-cli: prefer planning/review, not bulk implement
#
# Python 3.11+ is required to parse a local models.toml (stdlib tomllib).
# Older Python continues through Survival Guide / JSON / native when this file
# is absent; if the file is present without tomllib, validation fails closed.

[profiles.coding_worker]
adapter = "custom-cli"
executable = "my-coding-agent"
notes = "Example custom wrapper; replace executable for your environment"

[profiles.review_lens]
adapter = "claude-code"
# executable defaults to the adapter hint when omitted

# Example: high-quality Claude for plan/review, labor Claude for implement volume
# [profiles.claude-code-planning]
# adapter = "claude-code"
# # requested_model = "…"
# notes = "High-quality plan/review"
#
# [profiles.claude-code-labor]
# adapter = "claude-code"
# # requested_model = "…"
# notes = "Volume implement labor"
#
# Google subscription CLIs (plan/review; usually not bulk implement):
# [profiles.gemini-cli]
# adapter = "gemini-cli"
# executable = "gemini"
#
# [profiles.antigravity-cli]
# adapter = "antigravity-cli"
# executable = "antigravity"

[roles.planning]
profile = "host-native"
required = false

[roles.implement]
profile = "coding_worker"
required = false
fallback_chain = [
  { profile = "host-native", reason = "native fallback when worker unavailable" },
]

[roles.validate]
profile = "host-native"
required = true

[roles.review]
profile = "review_lens"
required = false
fallback_chain = [
  { profile = "host-native", reason = "keep review available without providers" },
]

# Lightweight review is independent of the supervising review/synthesize route.
[roles.lightweight_review]
profile = "host-native"
required = false

[roles.synthesize]
profile = "host-native"
required = true

[roles.scout]
profile = "host-native"
required = false

# Optional provider breadth (read-only plan/review/scout) — env var NAMES only:
# optional_env = ["OPENROUTER_API_KEY", "META_API_KEY", "MODEL_API_KEY", "GEMINI_API_KEY"]
#
# Geometry-exploration style: thin CLI wrappers + named presets, not prestige IDs in Elves core.
# Keys live in ignored .env.local. Missing key → host-native fallback.
#
# OpenRouter plan/review (scripts/openrouter_lens.py + OPENROUTER_API_KEY):
# [profiles.openrouter-lens]
# adapter = "custom-cli"
# executable = "scripts/openrouter_lens.py"
# # requested_model = "qwen/qwen3-max"   # any current OpenRouter provider/model id
#
# [profiles.or-qwen-max]
# adapter = "custom-cli"
# executable = "scripts/openrouter_lens.py"
# # requested_model = "qwen/qwen3-max"
#
# [profiles.or-glm]
# adapter = "custom-cli"
# executable = "scripts/openrouter_lens.py"
# # requested_model = "z-ai/glm-5"
#
# [roles.review]
# profile = "or-qwen-max"
# required = false
# fallback_chain = [
#   { profile = "host-native", reason = "OPENROUTER_API_KEY missing; keep review available" },
# ]
#
# Prefer exact session_id for plan→review continuity (openrouter_lens --session-id).
# If no session id, attach plan/constitution via packet relevant_files or --context-file.
#
# [profiles.muse_spark]
# adapter = "custom-cli"
# executable = "node"
# notes = "tools/meta_tools.mjs --model muse-spark-1.1; env META_API_KEY|MODEL_API_KEY; base api.meta.ai"
