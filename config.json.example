{
  "_comment": "Elves persistent preferences. Copy this to config.json and customize.",
  "_docs": "These values are read at session start so you don't have to reconfigure every time.",
  "batch_sizing": {
    "team_size": 4,
    "sprint_weeks": 2,
    "notes": "Adjust based on your model and stack. Codex can handle larger batches."
  },
  "notification": {
    "method": "gh-pr-comment",
    "_alternatives": "slack, custom-cmd, gh-pr-comment",
    "_comment": "PR comments are the zero-config fallback. Runtime completion notification order is ELVES_SLACK_WEBHOOK, then ELVES_NOTIFY_CMD, then PR comment unless your project overrides it."
  },
  "review": {
    "method": "github-pr-comments",
    "_alternatives": "github-pr-comments, custom-api"
  },
  "default_branch": "main",
  "cleanup": {
    "keep_plan": true,
    "_comment": "If false, the plan file is also removed in the final cleanup commit."
  },
  "memory_hygiene": {
    "archive_execution_log_after_entries": 50,
    "create_reactivation_handoff": true,
    "local_app_cleanup": "inspect-only-unless-user-requests-maintenance",
    "_comment": "Performance hygiene for long runs. Keep live docs concise, archive old log entries in place, and never mutate Codex/Claude app state during a coding run."
  },
  "cobbler": {
    "enabled": true,
    "coordination_default": "cobbler-first",
    "default_for_elves_runs": true,
    "default_mode": "quick",
    "default_backend": "native-subagents",
    "primary_invocations": {
      "claude_code": "/cobbler <task>",
      "codex": "$elves cobbler: <task>",
      "codex_natural": "Ask the Cobbler to <task>"
    },
    "compatibility_aliases": [
      "/council",
      "/ec",
      "/elves-council",
      "$elves council: <task>"
    ],
    "default_answer_shape": [
      "Recommendation",
      "Why this fits",
      "Strongest dissent",
      "Risks",
      "Next move",
      "Confidence"
    ],
    "harness_loop": {
      "capability_scan": [
        "repo-docs",
        "run-memory",
        "skills",
        "host-subagents",
        "tools",
        "tests",
        "pr-checks",
        "source-needs",
        "optional-provider-routes"
      ],
      "route_and_medium_selection": {
        "routes": [
          "direct-answer",
          "read-only-lenses",
          "scoped-workers",
          "tools-tests-source-checks",
          "run-coordination"
        ],
        "output_mediums": [
          "chat-answer",
          "file-edit",
          "pr-comment",
          "execution-log",
          ".elves-session.json",
          "elves-report",
          "artifact"
        ]
      },
      "context_packet": [
        "user-intent",
        "mode",
        "work-scope",
        "relevant-files",
        "run-state-pointers",
        "available-tools-skills",
        "source-freshness",
        "constraints",
        "forbidden-actions"
      ],
      "execute_agents_tools_skills": "host-native-first",
      "collect_evidence": [
        "role-reports",
        "file-references",
        "command-output",
        "tests",
        "pr-comments",
        "source-links",
        "changed-files",
        "risks",
        "dissent"
      ],
      "fit_answer": "one-recommendation-with-strongest-dissent",
      "present_record": "answer-user-record-material-run-decisions",
      "reclassify": [
        "direct-to-one-off",
        "one-off-to-run",
        "review-to-implementation",
        "release-to-blocker"
      ]
    },
    "default_role_count": 3,
    "max_role_count": 5,
    "quick_read_only": true,
    "quick_stateless": true,
    "run_logging": "existing-elves-memory",
    "model_routing_policy": "native-first",
    "provider_backed_council": {
      "enabled": false,
      "provider_policy": "optional-external-providers",
      "fallback": "native-subagent-and-note",
      "required_env": [],
      "optional_env": [
        "OPENROUTER_API_KEY",
        "META_API_KEY",
        "MODEL_API_KEY",
        "GEMINI_API_KEY",
        "ANTHROPIC_API_KEY",
        "XAI_API_KEY",
        "OPENAI_API_KEY"
      ],
      "role_models": {
        "default": "native-subagent",
        "architect": "native-subagent",
        "skeptic": "native-subagent",
        "implementation_analyst": "native-subagent",
        "tester": "native-subagent",
        "synthesis": "native-coordinator"
      },
      "external_route_examples": [
        "openrouter:<model-id>",
        "meta:muse-spark-1.1"
      ],
      "external_route_example": "openrouter:<model-id>",
      "meta_muse_notes": "Pin muse-spark-1.1 from Meta /v1/models; accept META_API_KEY or MODEL_API_KEY; independent review lane only",
      "role_effort": {
        "architect": "high",
        "skeptic": "high",
        "tester": "medium"
      }
    },
    "_comment": "Cobbler coordination defaults. Cobbler-first is the default for Elves runs; Quick Cobbler is the one-off answer mode. Provider-backed council and role model routing are opt-in; do not hardcode private keys."
  },
  "council": {
    "compatibility_for": "cobbler",
    "precedence": "cobbler",
    "enabled": true,
    "default_mode": "quick",
    "default_backend": "native-subagents",
    "aliases": [
      "/council",
      "/ec",
      "/elves-council"
    ],
    "quick_read_only": true,
    "quick_stateless": true,
    "run_logging": "existing-elves-memory",
    "provider_backed": {
      "enabled": false,
      "provider_policy": "optional-external-providers",
      "required_env": []
    },
    "_comment": "Legacy v1.14 Council-compatible config. Prefer the top-level cobbler block in new configs. If both blocks are present, cobbler wins; keep council for older projects that already refer to council keys."
  },
  "model_routing": {
    "enabled": false,
    "policy": "native-first",
    "fallback": "host-native",
    "required": false,
    "phases": {
      "implement": {
        "preference": "strongest-host-native",
        "provider_backed_allowed": false,
        "notes": "Use the main coding agent or a host-native implementation subagent."
      },
      "validate": {
        "preference": "reliable-host-native",
        "provider_backed_allowed": false,
        "notes": "Run commands locally and prioritize reproducible evidence."
      },
      "review": {
        "preference": "independent-lens",
        "provider_backed_allowed": true,
        "notes": "Prefer a fresh model or subagent when available."
      },
      "scout": {
        "preference": "broad-fast-lens",
        "provider_backed_allowed": true,
        "notes": "Use optional external providers for breadth only when configured."
      },
      "synthesize": {
        "preference": "coordinator",
        "provider_backed_allowed": true,
        "notes": "Return one fitted answer with dissent and next action."
      }
    },
    "log_material_fallbacks": true,
    "_comment": "Optional full-run phase routing preferences. Advisory unless the host or configured provider supports the route. Missing optional provider access falls back to host-native and does not block ordinary Elves or Cobbler use."
  },
  "api_surface_snapshot": {
    "enabled": "auto",
    "required": false,
    "baseline_path": ".elves/api-surface/baseline.json",
    "current_path": ".elves/api-surface/current.json",
    "diff_path": ".elves/api-surface/diff.md",
    "sources": {
      "rest": "auto",
      "graphql": "auto",
      "exports": "auto",
      "cli": "auto",
      "events": "auto",
      "config": "auto"
    },
    "policy": {
      "unavailable_source": "warning",
      "additive_change": "info",
      "intentional_breaking_change": "requires-plan-note",
      "unexpected_breaking_change": "blocking"
    },
    "_comment": "Optional public API surface snapshot preferences. In auto mode, missing sources are advisory. required=true belongs in a project survival guide only when explicitly opted in; snapshots are regression evidence, not authority."
  },
  "math": {
    "enabled": false,
    "coordination": "cobbler-managed-domain-workflow",
    "provider_policy": "native-first-with-optional-external-routes",
    "required_env": [],
    "optional_env": [
      "OPENROUTER_API_KEY",
      "GEMINI_API_KEY",
      "ANTHROPIC_API_KEY",
      "XAI_API_KEY",
      "OPENAI_API_KEY",
      "EXA_API_KEY"
    ],
    "ledger_dir": "docs/math",
    "role_models": {
      "subfield_scout": "native-subagent",
      "cross_field_synthesizer": "native-coordinator",
      "proof_critic": "native-subagent",
      "derivation_checker": "native-subagent",
      "source_auditor": "native-subagent",
      "exposition_editor": "native-subagent",
      "formalization_scout": "native-subagent",
      "evolutionary_search": "off"
    },
    "optional_tools": [
      "alphaevolve"
    ],
    "external_route_examples": {
      "subfield_scout": "openrouter:<model-id>",
      "proof_critic": "openrouter:<model-id>",
      "evolutionary_search": "alphaevolve:<task-id>"
    },
    "alphaevolve": {
      "enabled": false,
      "auth": "gcloud-impersonation",
      "artifact_dir": "alphaevolve_runs",
      "promote_policy": "independent-local-replay-only",
      "notes": "Optional Google Cloud AlphaEvolve for numerical examples/counterexample signals; not a proof engine. Prefer short-lived gcloud impersonation; never store service-account keys in the repo."
    },
    "fallback_policy": "record-before-switching-provider",
    "_comment": "Optional math research workflow configuration. Math is a Cobbler-managed domain workflow. Configure role slots in your project survival guide; do not hardcode private keys or provider secrets. OPENROUTER_API_KEY and AlphaEvolve are optional unless a project survival guide explicitly requires them."
  },
  "risk_policy_v2_2": {
    "thin_safety_kernel": true,
    "risk_tiers": [
      "trivial/docs",
      "standard trusted",
      "high-risk trusted",
      "untrusted"
    ],
    "proof_budget": "validate once, verify changes, attest final",
    "per_batch_default": "touched_surfaces",
    "broad_at": [
      "risk_checkpoints",
      "terminal_readiness"
    ],
    "mid_run_pr_feedback": "nonblocking_new_unresolved_only",
    "terminal_pr_feedback": "wait_required_checks_and_reviewers",
    "_comment": "v2.2 risk-tiered execution policy pins for operator surfaces"
  }
}
